# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=argenprecios

# Concurrency (adjust per hardware)
# PC de alto rendimiento: 12-24
# VPS 2GB RAM: 1-2
MAX_CONCURRENT_BROWSERS=2
MAX_CONCURRENT_PAGES=3

# Schedule (24h format, Argentina UTC-3)
SCHEDULE_HOUR_1=6
SCHEDULE_HOUR_2=12

# Data retention (days)
TTL_DAYS=30

# Retry config
RETRY_INTERVAL_MINUTES=15
MAX_RETRIES=3

# API
API_HOST=0.0.0.0
API_PORT=8000

# Timezone
TZ=America/Argentina/Buenos_Aires

# Google OAuth (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# Allowlist: comma-separated Gmail addresses allowed to log in
ALLOWED_EMAILS=tu@gmail.com

# Frontend URL (for post-login redirect)
FRONTEND_URL=http://localhost:8000

# Cookie security: False for localhost, True for HTTPS production
COOKIE_SECURE=False

