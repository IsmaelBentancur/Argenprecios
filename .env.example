# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=argenprecios

# Concurrency (adjust per hardware)
# PC de alto rendimiento: 12-24
# VPS 2GB RAM: 1-2
MAX_CONCURRENT_SCRAPERS=2

# Schedule (24h format, Argentina UTC-3)
SCHEDULE_HOUR_1=6
SCHEDULE_HOUR_2=12

# Data retention (days)
TTL_DAYS=30

# Retry config
RETRY_INTERVAL_MINUTES=15
MAX_RETRIES=3

# API
API_HOST=0.0.0.0
API_PORT=8000

# Timezone
TZ=America/Argentina/Buenos_Aires
